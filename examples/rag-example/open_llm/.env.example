# AltaStata (required for indexing and query)
# Path on host to your AltaStata account directory. Use $HOME or absolute path (Docker does not expand ~)
# Examples:
#   ALTASTATA_ACCOUNT_DIR=$HOME/.altastata/accounts/amazon.rsa.bob123
#   ALTASTATA_ACCOUNT_DIR=$HOME/.altastata/accounts/azure.rsa.bob123
ALTASTATA_ACCOUNT_DIR=$HOME/.altastata/accounts/amazon.rsa.bob123
ALTASTATA_PASSWORD=123
ALTASTATA_ACCOUNT_ID=bob123
ALTASTATA_CALLBACK_PORT=25334
# Path to index on startup before listening (default RAGDocs/policies). Set empty to only listen.
# RAG_INDEX_PATH=RAGDocs/policies

# Vector store path (default: ./local_index)
# LOCAL_INDEX_PATH=./local_index

# Embeddings (local model)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM: if unset, auto-uses Ollama when running. Set LLM_PROVIDER=mlx for fastest on M1/Mac; transformers for 390.
# For Ollama install: pip install langchain-ollama. For watsonx: pip install langchain-ibm.
# LLM_PROVIDER=ollama
# Ollama: default model is smollm2:360m (fast). Pull with: ollama pull smollm2:360m. Alternatives: qwen2.5:0.5b, llama3.2:1b
# OLLAMA_MODEL=smollm2:360m
# OLLAMA_NUM_PREDICT=128

# MLX (Mac only, fastest on M1): pip install mlx mlx-lm. Models: mlx-community/Llama-3.2-1B-Instruct-4bit, etc.
# LLM_PROVIDER=mlx
# MLX_MODEL=mlx-community/Llama-3.2-1B-Instruct-4bit
# MLX_MAX_TOKENS=128

# Transformers (same on Mac, Docker, IBM 390): default TinyLlama. Faster: HF_LLM_MODEL=HuggingFaceTB/SmolLM2-360M-Instruct. Fastest (weak): gpt2
# HF_LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
# HF_LLM_MAX_NEW_TOKENS=80

# IBM watsonx / Granite (IBM Cloud API): fast from Mac, Docker, 390. Get API key: https://cloud.ibm.com/docs/account?topic=account-userapikey
# LLM_PROVIDER=watsonx
# WATSONX_APIKEY=your-ibm-cloud-api-key
# WATSONX_PROJECT_ID=your-watsonx-project-id
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2
# WATSONX_MAX_TOKENS=128

# OLLAMA_BASE_URL=http://localhost:11434

# Web app
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Query timeout in seconds (default 180; use Ollama on Mac for faster answers)
# QUERY_TIMEOUT=180
# HTTPS (optional – set both to enable)
# SSL_CERT_FILE=/path/to/cert.pem
# SSL_KEY_FILE=/path/to/key.pem

# Chunking
# RAG_CHUNK_SIZE=4000
# RAG_CHUNK_OVERLAP=800
