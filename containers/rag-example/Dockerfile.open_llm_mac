# AltaStata RAG – Open LLM stack for Mac (arm64/amd64), same layout as s390x
# Build from repo root: docker build -f containers/rag-example/Dockerfile.open_llm_mac -t altastata/rag-open-llm:latest .
# No sample_documents; documents from AltaStata. Index built at startup if ALTASTATA_ACCOUNT_DIR set and no index.
# On Mac you can use LLM_PROVIDER=ollama and run Ollama on the host (faster) or LLM_PROVIDER=transformers (same as s390x).

FROM python:3.11-slim

LABEL maintainer="Altastata Team"
LABEL description="AltaStata RAG Open LLM (Mac – simple vector store + AltaStata, same as s390x layout)"
LABEL org.opencontainers.image.source="https://github.com/altastata/altastata-python-package"

WORKDIR /app

# Java and build deps for AltaStata and sentence-transformers (same pattern as examples/rag-example/open_llm/Dockerfile)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# default-jre-headless puts java on PATH; JAVA_HOME optional for some tools
RUN python -m pip install --upgrade pip

# RAG app dependencies (cached unless requirements.txt changes)
COPY examples/rag-example/open_llm/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Install AltaStata from repo copy only
COPY . /src/altastata-python-package
RUN pip install --no-cache-dir /src/altastata-python-package

# App code (no sample_documents; documents come from AltaStata)
COPY examples/rag-example/open_llm /app/open_llm

RUN chmod +x /app/open_llm/docker-entrypoint.sh
RUN mkdir -p /app/open_llm/local_index

ENV PYTHONPATH=/app/open_llm:/src/altastata-python-package
ENV PYTHONUNBUFFERED=1
ENV WEB_HOST=0.0.0.0
ENV WEB_PORT=8000
ENV VECTOR_STORE=simple
ENV LOCAL_INDEX_PATH=/app/open_llm/local_index
# Use Transformers by default (same as s390x). Override with -e LLM_PROVIDER=ollama if using Ollama on host.
ENV LLM_PROVIDER=transformers

VOLUME /app/open_llm/local_index
EXPOSE 8000

WORKDIR /app/open_llm
ENTRYPOINT ["/app/open_llm/docker-entrypoint.sh"]
CMD ["python", "-m", "uvicorn", "web_app:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]
