# Build stage - AMD64 base image
# Note: Base image is AMD64-only. ARM64/s390x builds will use emulation (QEMU) via buildx
# TARGETPLATFORM avoids "constant value" warning when building (e.g. buildx for amd64)
ARG TARGETPLATFORM=linux/amd64
FROM --platform=$TARGETPLATFORM quay.io/opendatahub-contrib/workbench-images:jupyter-datascience-c9s-py311_2023c_latest

LABEL maintainer="Altastata Team"
LABEL version="1.0.0"
LABEL description="Altastata Jupyter DataScience (AMD64 base, supports AMD64/ARM64/s390x via buildx)"
LABEL org.opencontainers.image.source="https://github.com/altastata/altastata-python-package"

USER root

# Install Java 17
RUN dnf install -y java-17-openjdk-devel && \
    dnf clean all

# Set JAVA_HOME
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk

# Create Jupyter configuration directory and set permissions
RUN mkdir -p /home/jovyan/.jupyter && \
    chown -R 1001:0 /home/jovyan/.jupyter && \
    chmod -R g+rwX /home/jovyan/.jupyter && \
    chown -R 1001:0 /opt/app-root/src && \
    chmod -R g+rwX /opt/app-root/src

# Copy requirements files
COPY --chown=1001:0 containers/jupyter/requirements.txt ./
COPY --chown=1001:0 containers/jupyter/pytorch-cpu.txt ./

# Install regular dependencies first
RUN echo "Installing regular packages" && \
    pip install --no-cache-dir --upgrade-strategy only-if-needed -r requirements.txt

# Install PyTorch CPU-only versions
RUN echo "Installing PyTorch CPU packages" && \
    pip install --no-cache-dir --upgrade-strategy only-if-needed -r pytorch-cpu.txt --index-url https://download.pytorch.org/whl/cpu

# Install AltaStata in its own layer — pinned via build ARG so bumping the version
# invalidates only this small layer (PyTorch / requirements layers above stay cached).
# Single source of truth lives in setup.py: the build scripts
# (containers/jupyter/build-all-images.sh, push-to-ghcr.sh) source version.sh
# which auto-extracts ALTASTATA_PYPI_VERSION from setup.py and forwards it as
# --build-arg ALTASTATA_VERSION. ARG default is intentionally empty: ad-hoc
# `docker build .` then installs the latest from PyPI; the build script always
# pins to setup.py's version, which is the canonical path.
ARG ALTASTATA_VERSION=
RUN if [ -n "${ALTASTATA_VERSION}" ]; then \
        pip install --no-cache-dir "altastata==${ALTASTATA_VERSION}" ; \
    else \
        echo "WARN: ALTASTATA_VERSION not set (build script overrides this). Installing latest from PyPI." && \
        pip install --no-cache-dir altastata ; \
    fi
# gRPC stubs in altastata.v1 are generated with grpcio-tools 1.80.x.
RUN pip install --no-cache-dir "grpcio>=1.80.0"

# Copy pytorch-example for reference
COPY --chown=1001:0 examples/pytorch-example /opt/app-root/src/pytorch-example/

# Set proper permissions
RUN chown -R 1001:0 /opt/app-root/src/pytorch-example && \
    chmod -R g+rwX /opt/app-root/src/pytorch-example

# Switch to non-root user for remaining operations
USER 1001

# Verify that altastata is installed and working (from pip)
RUN echo "Verifying altastata installation:" && \
    python -c "import altastata; print('Module location:', altastata.__file__)" && \
    python -c "from altastata import AltaStataFunctions; print('AltaStataFunctions imported successfully')" && \
    echo "✅ AltaStata package is ready!"

# Configure Jupyter
WORKDIR /home/jovyan
USER root
RUN echo '{"ServerApp": {"token": "", "allow_origin": "*", "allow_credentials": true}}' > /home/jovyan/.jupyter/jupyter_server_config.json
USER 1001

# Expose Jupyter port
EXPOSE 8888

# Set environment variables for Jupyter
ENV JUPYTER_ENABLE_LAB=yes
ENV JUPYTER_CONFIG_DIR=/home/jovyan/.jupyter

# Set the image label
LABEL org.opencontainers.image.title="altastata/jupyter-datascience"
LABEL org.opencontainers.image.description="Jupyter DataScience environment with AltaStata integration"
LABEL org.opencontainers.image.version="latest"

CMD ["start-notebook.sh"]